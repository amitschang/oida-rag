# OIDA assistant configuration. Copy to `oida.toml` and edit.
# All fields are optional; the values below are the defaults.

# Directory containing artifact files on disk, keyed by artifact_name.
# Leave unset if you don't have the artifacts yet; artifact-text tools
# will report `artifact_root_not_configured` and degrade gracefully.
# artifact_root = "/path/to/artifacts"

# Local Ollama endpoint and model used to drive tool calling.
ollama_host = "http://localhost:11434"
ollama_model = "qwen2.5-coder:latest"

# LanceDB database directory. Holds the document/artifact metadata tables
# (`oida-cli ingest --force`) and, when built, the hybrid keyword + semantic
# text index over artifact OCR text (`oida-cli ingest --force --full-text`).
lance_path = "oida-lance"

# Ollama model used to embed document text and queries for semantic search.
# This is only the default used when building the index; queries always use
# the model recorded in the index so search can never disagree with the
# stored vectors. Pull it first, e.g. `ollama pull nomic-embed-text`.
embed_model = "nomic-embed-text"

# Text chunking for the semantic index. Each artifact's text is split into
# overlapping byte-bounded chunks before embedding.
chunk_bytes = 2048
chunk_overlap = 256

# In-memory write-buffer target (bytes) for the hybrid index build. Embedded
# chunk batches accumulate to this size, then flush to LanceDB as one fragment.
# Larger = fewer/bigger fragments (less churn) but higher peak memory. ~1 GiB.
write_buffer_bytes = 1073741824

# Compact the chunks table after building the hybrid index, merging any
# leftover small fragments and pruning old versions before indexes are built.
compact_on_build = true

# In-memory buffer target (bytes) before the `ingest` step flushes a LanceDB
# fragment for the documents/artifacts tables. Larger = fewer, bigger fragments
# (better read performance, less metadata) but higher peak memory during ingest.
# ~512 MiB. Raise on large-memory nodes for fewer files.
ingest_buffer_bytes = 536870912

# Store raw (non-text) artifact bytes in a `raw_artifacts` blob table during
# `oida-cli ingest` (pass `--store-raw`). The bytes are fetched from the
# artifact source below; the text/plain OCR chunk index is built regardless.
# store_raw_artifacts = false

# Target size, in bytes, of each `raw_artifacts` LanceDB fragment. Fetched blobs
# (whose individual sizes vary widely) accumulate until their combined size
# reaches this target, then flush as one fragment, keeping file sizes even.
# Larger = fewer, bigger files at the cost of higher peak memory and a coarser
# resume checkpoint. ~256 MiB.
# raw_file_bytes = 268435456

# Artifact source for raw storage and the full-text reader. When `s3_bucket`
# is set, artifacts are fetched from S3 (using the same fan-out key layout as
# the on-disk store, under `s3_prefix`) instead of `artifact_root`. S3
# credentials come from the standard AWS environment (AWS_ACCESS_KEY_ID, …),
# not this file. `s3_endpoint` targets S3-compatible stores (MinIO, Ceph, R2).
# s3_bucket = "my-artifacts"
# s3_region = "us-east-1"
# s3_endpoint = "https://minio.example.com"
# s3_prefix = "artifacts"

